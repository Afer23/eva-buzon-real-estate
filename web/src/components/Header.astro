---
import {getLangFromUrl, useTranslations, localizedPath} from '@/i18n/utils'
import LanguageSwitcher from './LanguageSwitcher.astro'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
---

<header class="border-b border-ink-200/40 bg-bone/80 backdrop-blur sticky top-0 z-30">
  <div class="container-x flex items-center justify-between h-16">
    <a href={localizedPath(lang, '/')} class="font-serif text-xl tracking-tight">
      Eva Buzón
    </a>
    <nav class="hidden md:flex items-center gap-8 text-sm">
      <a href={localizedPath(lang, '/')} class="hover:text-terracotta">{t('nav.home')}</a>
      <a href={localizedPath(lang, '/propiedades')} class="hover:text-terracotta">{t('nav.properties')}</a>
      <a href={localizedPath(lang, '/sobre')} class="hover:text-terracotta">{t('nav.about')}</a>
      <a href={localizedPath(lang, '/contacto')} class="hover:text-terracotta">{t('nav.contact')}</a>
    </nav>
    <div class="flex items-center gap-3">
      <LanguageSwitcher />
      <button id="menu-toggle" class="md:hidden p-2" aria-label="Menu">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
    </div>
  </div>
  <nav id="mobile-menu" class="hidden md:hidden border-t border-ink-200/40 bg-bone">
    <div class="container-x py-4 flex flex-col gap-3 text-sm">
      <a href={localizedPath(lang, '/')}>{t('nav.home')}</a>
      <a href={localizedPath(lang, '/propiedades')}>{t('nav.properties')}</a>
      <a href={localizedPath(lang, '/sobre')}>{t('nav.about')}</a>
      <a href={localizedPath(lang, '/contacto')}>{t('nav.contact')}</a>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('menu-toggle')
  const menu = document.getElementById('mobile-menu')
  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'))
</script>
